{
  "expo": {
    "name": "Job Portal",
    "slug": "mobile",
    "scheme": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bitcode": false
    },
    "android": {
      "package": "com.joseph.jobportal",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro",
      "output": "server"
    },
    "plugins": [
      [
        "@livekit/react-native-expo-plugin"
      ],
      [
        "@config-plugins/react-native-webrtc"
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Job Portal to use your camera for video calls."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow Job Portal to use your microphone for calls."
        }
      ],
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ceee6f45-f5c1-41b9-ac1c-cbb3eb46b5ff"
      }
    },
    "owner": "joseph_k"
  }
}
