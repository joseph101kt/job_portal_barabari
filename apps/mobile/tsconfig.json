{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "types": ["node"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@my-app/ui": ["../../packages/ui/src/index.ts"],
      "@my-app/features": ["../../packages/features/src/index.native.ts"],
      "@my-app/features/livekit/web": ["../../packages/features/src/livekit/web/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "nativewind-env.d.ts"
  ]
}